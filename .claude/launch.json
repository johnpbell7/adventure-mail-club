{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{let p='.'+new URL(q.url,'http://x').pathname;if(p==='./') p='./index.html';require('fs').readFile(p,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{let t='text/html';if(p.endsWith('.css'))t='text/css';if(p.endsWith('.js'))t='text/javascript';if(p.endsWith('.jpg'))t='image/jpeg';if(p.endsWith('.png'))t='image/png';r.writeHead(200,{'Content-Type':t});r.end(d)}})}).listen(8080)"],
      "port": 8080
    }
  ]
}
